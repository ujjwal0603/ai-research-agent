# ============================================
# AI Research Agent Platform — Production Config
# ============================================
# Copy this file and fill in real values.
# NEVER commit the filled-in version to git.

# ── App ──────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ── Security (CRITICAL) ─────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_GENERATE_A_SECURE_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database (Neon PostgreSQL) ──────────────
# Get from: https://console.neon.tech → Connection Details
# IMPORTANT: Change postgresql:// to postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?sslmode=require

# ── Vector Database (Qdrant Cloud) ──────────
# Get from: https://cloud.qdrant.io → Cluster → Dashboard
QDRANT_URL=https://your-cluster.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_IN_MEMORY=false

# ── LLM API Keys ────────────────────────────
# At least one is required for chat/reasoning
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
DEFAULT_LLM_PROVIDER=auto

# ── Redis (Optional — Upstash) ──────────────
# Get from: https://console.upstash.com
# Leave default if not using Redis
REDIS_URL=redis://localhost:6379/0

# ── CORS (Frontend URL) ─────────────────────
# Must match your Vercel deployment URL exactly
CORS_ORIGINS=["https://your-app.vercel.app"]

# ── ML Models ───────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ── File Upload ─────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=50

# ── Logging ─────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
